# =============================================================================
# Otaku-mori — Example environment file (PLACEHOLDERS ONLY)
# =============================================================================
# This file documents the environment variables the app reads via `env.mjs`.
# It contains NO real secrets. Copy it to `.env.local` for local development
# and fill in your own values. NEVER commit a file that contains real values.
#
#   cp .env.example .env.local
#
# - Local development: use `.env.local` (gitignored).
# - Preview / Production: managed in the Vercel dashboard and provider
#   dashboards, NOT in Git. See docs/security/env-handling.md.
# =============================================================================

# ---------------------------------------------------------------------------
# Core / runtime
# ---------------------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database — Neon / Postgres (and optional Prisma Accelerate)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
PRISMA_ACCELERATE_API_KEY=

# ---------------------------------------------------------------------------
# Stripe (payments)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-signing-secret>
STRIPE_WEBHOOK_FULFILLMENT_DRY_RUN=true
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>

# ---------------------------------------------------------------------------
# Fulfillment provider selection
# ---------------------------------------------------------------------------
FULFILLMENT_PROVIDER=disabled
FULFILLMENT_DRY_RUN=true

# ---------------------------------------------------------------------------
# Clerk (authentication)
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=<your-clerk-secret-key>
CLERK_WEBHOOK_SECRET=<your-clerk-webhook-secret>
CLERK_ENCRYPTION_KEY=<your-clerk-encryption-key>
CLERK_PROXY_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
NEXT_PUBLIC_CLERK_PROXY_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_DOMAIN=

# ---------------------------------------------------------------------------
# Printify (provider)
# ---------------------------------------------------------------------------
PRINTIFY_API_KEY=replace-with-printify-api-key
PRINTIFY_SHOP_ID=000000
PRINTIFY_API_URL=https://api.printify.com/v1
PRINTIFY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Merchize (optional provider)
# ---------------------------------------------------------------------------
MERCHIZE_API_URL=
MERCHIZE_STORE_API_URL=
MERCHIZE_ACCESS_TOKEN=
MERCHIZE_API_TOKEN=
MERCHIZE_WEBHOOK_SECRET=
NEXT_PUBLIC_MERCHIZE_API_URL=

# ---------------------------------------------------------------------------
# Upstash Redis (rate limiting / caching)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

# ---------------------------------------------------------------------------
# Vercel Blob (file storage)
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=
BLOB_READ_WRITE_URL=
BLOB_PUBLIC_BASE_URL=
BLOB_BUCKET_PREFIX=om

# ---------------------------------------------------------------------------
# Resend (email)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_ADMIN_API_KEY=
RESEND_ADMIN_KEY=
EMAIL_FROM=hello@example.com
EMAIL_DRY_RUN=true
EMAIL_SEND_ENABLED=false

# ---------------------------------------------------------------------------
# Inngest (background jobs)
# ---------------------------------------------------------------------------
INNGEST_SERVE_URL=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_PROBE=

# ---------------------------------------------------------------------------
# EasyPost (shipping) + default ship-from address
# ---------------------------------------------------------------------------
EASYPOST_API_KEY=
EASYPOST_WEBHOOK_SECRET=
DEFAULT_SHIP_FROM_NAME=
DEFAULT_SHIP_FROM_STREET=
DEFAULT_SHIP_FROM_CITY=
DEFAULT_SHIP_FROM_STATE=
DEFAULT_SHIP_FROM_ZIP=
DEFAULT_SHIP_FROM_COUNTRY=

# ---------------------------------------------------------------------------
# Algolia (search)
# ---------------------------------------------------------------------------
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_INDEX_BLOG=
ALGOLIA_INDEX_GAMES=
ALGOLIA_INDEX_PAGES=
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# ---------------------------------------------------------------------------
# Sanity (CMS)
# ---------------------------------------------------------------------------
SANITY_WEBHOOK_SECRET=
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_READ_TOKEN=
SANITY_API_VERSION=

# ---------------------------------------------------------------------------
# Sentry (observability)
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_SKIP_AUTO_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# PostHog / GA (analytics)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Supabase (legacy — only if still present)
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Internal secrets / auth salts / cron
# ---------------------------------------------------------------------------
PETAL_SALT=replace-with-random-salt
AUTH_SECRET=replace-with-random-secret
API_KEY=
INTERNAL_AUTH_TOKEN=
CRON_SECRET=
ADMIN_EMAILS=
AUTHORIZED_PARTIES=

# ---------------------------------------------------------------------------
# App URLs / metadata
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CANONICAL_ORIGIN=http://localhost:3000
BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_APP_ENV=development

# ---------------------------------------------------------------------------
# Content gating
# ---------------------------------------------------------------------------
NSFW_GLOBAL=off

# ---------------------------------------------------------------------------
# Petal discount vouchers (optional tuning)
# ---------------------------------------------------------------------------
PETAL_DISCOUNT_ENABLED=false
PETAL_DISCOUNT_MIN_ORDER_CENTS=2000
PETAL_DISCOUNT_MAX_PERCENT=15
PETAL_DISCOUNT_MAX_PER_USER_MONTH=3

# ---------------------------------------------------------------------------
# Feature flags (client)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FEATURE_MINIGAMES=on
NEXT_PUBLIC_FEATURE_RUNE=off
NEXT_PUBLIC_FEATURE_SOAPSTONE=on
NEXT_PUBLIC_FEATURE_PETALS=on
NEXT_PUBLIC_FEATURE_CURSOR_GLOW=off
NEXT_PUBLIC_FEATURE_STARFIELD=on
